# ─── Ethereum Sepolia (default network) ───────────────────────────────
CONTRACT_ADDRESS=0x...
RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# ─── Base Sepolia (optional) ──────────────────────────────────────────
# Used automatically when the connected wallet is on Base Sepolia (84532).
# Leave blank if you are not deploying to Base.
CONTRACT_ADDRESS_BASE=0x...
RPC_URL_BASE=https://base-sepolia-rpc.publicnode.com

# football-data.org API key — used by the Vite dev proxy to list upcoming matches
FOOTBALL_API_KEY=your_football_data_api_key
